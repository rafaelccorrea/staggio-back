# ============================================
# Staggio API - Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=development

# ============================================
# Supabase (Database + Storage + Auth)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase PostgreSQL (TypeORM connection)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_supabase_db_password
DB_DATABASE=postgres
DB_SSL=true

# ============================================
# JWT
# ============================================
JWT_SECRET=your_jwt_secret_key_minimum_32_chars
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# ============================================
# OpenAI (AI Features)
# ============================================
OPENAI_API_KEY=sk-your_openai_api_key

# ============================================
# Stripe (Payments & Subscriptions)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_STARTER_PRICE_ID=price_starter_id
STRIPE_PRO_PRICE_ID=price_pro_id
STRIPE_AGENCY_PRICE_ID=price_agency_id

# ============================================
# HeyGen (AI Video Generation)
# ============================================
HEYGEN_API_KEY=sk_your_heygen_api_key
HEYGEN_WEBHOOK_SECRET=your_heygen_webhook_secret

# ============================================
# Firebase (Google Sign-In)
# ============================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# Supabase Storage (replaces AWS S3)
# ============================================
SUPABASE_STORAGE_BUCKET=staggio-uploads

# ============================================
# App URLs
# ============================================
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080
